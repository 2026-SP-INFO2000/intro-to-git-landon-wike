


year = int(input('Enter year: '))

if (year % 4 == 0 and year % 100 != 0) or (year % 400 == 0):
    print(year, 'is a leap year!')
else:
    print(year, 'is not a leap year')





balance = 4000
withdrawal = float(input('Enter withdrawl amount: '))

if withdrawal < balance:
    remaining = balance - withdrawal
    formatted_remaining = f"{remaining:.2f}"
    print('Your remaining balance is $',formatted_remaining)
else: 
    print('Invalid withdrawal')





import random

target = random.randint(1, 10)   # random int between 1 and 10 (inclusive)





counter = 0
guess = int(input('Enter your guess: '))

if guess == target:
        print('Correct!')
elif abs(guess - target) == 1:
        print('Close!')
elif guess > target + 1: 
        print('Too High')
elif guess < target - 1:
        print('Too Low')





counter +=1





grade = float(input('Enter your grade: '))

if grade >= 97:
    print('A+')
elif grade >= 93:
    print('A')
elif grade >= 90:
    print('A-')
elif grade >= 87:
    print('B+')
elif grade >= 83:
    print('B')
elif grade >= 80:
    print('B-')
elif grade >= 77:
    print('C+')
elif grade >= 73:
    print('C')
elif grade >= 70:
    print('C-')
elif grade >= 60:
    print('D')
else:
    print('F')





score = float(input('Enter exam score: '))
