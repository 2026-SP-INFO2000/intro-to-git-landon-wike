# Another way using nested conditionals
age = float(input("What is your age?"))
has_id = bool(input("Do you have an ID? Enter 1 for yes, 0 for no"))
if age >= 18:
    if has_id:
        print('You can vote!')
    else:
        print('You cannot vote!')
else:
    print('You cannot vote!')





x = 15
if x > 0:
    if x % 2 == 0:
        print('Positive even')
    else:
        print('Positive odd')
else:
    print('Non-positive number')





x = 15
if x > 0 and x % 2 == 0:
    print('Positive even')
elif x > 0 and x % 2 != 0:
    print('Positive odd')
else:
    print('Non-positive number')





