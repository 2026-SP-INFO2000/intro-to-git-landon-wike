cart = {}

def add_item(item):
    if item in cart:
        cart[item] += 1
    else:
        cart[item] = 1

def show_cart():
    return cart

add_item("apple")
add_item("banana")
add_item("apple")
print(show_cart())





def pig_latin(word):
    return word[1:] + word[0] + "ay"

