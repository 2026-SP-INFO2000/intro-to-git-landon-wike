a = float(input('What is your coefficient for a?'))
b = float(input('What is your coefficient for b?'))
c = float(input('What is your coefficient for c?'))

descrim = b**2 - 4*a*c

# Calculate roots
x1 = (-b + descrim**0.5) / (2*a)
x2 = (-b - descrim**0.5) / (2*a)

# Print result
print("x =", x1)
print("x =", x2)





